# -----------------------------------------------------------------------------
# Example environment file for LDAP + SSSD + PAM integration
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in your organization’s details.
# The setup script will source these values automatically.
# -----------------------------------------------------------------------------

# === LDAP CONNECTION SETTINGS ================================================

# URI of your LDAP or Authentik directory
# Examples: ldap://ldap.internal.company.net   or   ldaps://ldap01.example.com
LDAP_URI="ldap://ldap.example.com"

# Base DN for your LDAP tree
LDAP_BASE_DN="dc=example,dc=com"

# Bind DN used for LDAP queries (service account)
LDAP_BIND_DN="cn=binduser,ou=service_accounts,dc=example,dc=com"

# Bind password for the above DN
LDAP_BIND_PASSWORD="super-secret-password"

# === LDAP ACCESS CONTROL GROUPS ==============================================

# Group that grants SSH + login access
# Example: cn=i-server-login,ou=groups,dc=example,dc=com
LOGIN_GROUP="cn=i-server-login,ou=groups,dc=example,dc=com"

# Group that grants passwordless sudo privileges
# Example: cn=i-a-server_admins,ou=groups,dc=example,dc=com
SUDO_GROUP="cn=i-a-server_admins,ou=groups,dc=example,dc=com"

# === LOCAL BREAK-GLASS USER ==================================================

# Always-available local account for emergency access
BREAK_GLASS_USER="localadmin"
